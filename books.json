<!DOCTYPE html>
<html lang="ar">
<head>
    <meta charset="UTF-8">
    <title>مكتبة إسماعيل سليمان حسن</title>

    <style>
        body {
            font-family: Tahoma, sans-serif;
            background-color: #eef2f7;
            text-align: center;
            padding: 30px;
        }

        img {
            border-radius: 50%;
            margin: 20px 0;
        }

        h1 {
            color: #0d6efd;
        }

        p {
            font-size: 18px;
            color: #333;
        }

        .book {
            background: white;
            margin: 10px auto;
            padding: 10px;
            width: 80%;
            border-radius: 10px;
        }

        a {
            text-decoration: none;
            color: green;
            font-weight: bold;
        }
    </style>
</head>

<body>

<h1>مرحبًا بكم في مكتبة إسماعيل سليمان حسن</h1>

<img src="images/ismail_photo.jpg" width="150">

<p>كتب الصف الأول الابتدائي:</p>

<div id="books"></div>

<script>
fetch('books.json')
.then(response => response.json())
.then(data => {

    let container = document.getElementById('books');

    data.forEach(book => {

        if (book.مرحلة === "ابتدائي" && book.صف === "الأول") {

            let div = document.createElement('div');
            div.className = 'book';

            div.innerHTML = `
                <p>${book.مادة} - ${book.نوع} (${book.سنة})</p>
                <a href="${book.رابط}" target="_blank">تحميل الكتاب</a>
            `;

            container.appendChild(div);
        }
    });

});
</script>

</body>
</html>
