<!DOCTYPE html>
<html lang="ar">

<head>

<meta charset="UTF-8">

<title>مكتبة إسماعيل سليمان حسن التعليمية</title>

<style>

body{
font-family:Tahoma;
direction:rtl;
background:#eef2f7;
margin:0;
}

header{
background:#0d6efd;
color:white;
padding:20px;
text-align:center;
font-size:28px;
}

section{
padding:20px;
}

h2{
background:#198754;
color:white;
padding:10px;
}

.book{
background:white;
margin:8px;
padding:10px;
border-radius:6px;
display:flex;
justify-content:space-between;
}

a{
background:#0d6efd;
color:white;
padding:6px 12px;
text-decoration:none;
border-radius:4px;
}

</style>

</head>

<body>

<header>

📚 مكتبة إسماعيل سليمان حسن التعليمية

</header>

<section>

<h2>المرحلة الابتدائية</h2>

<div id="primary"></div>

<h2>المرحلة المتوسطة</h2>

<div id="middle"></div>

<h2>المرحلة الثانوية</h2>

<div id="secondary"></div>

</section>

<script>

fetch("books.json")

.then(response => response.json())

.then(data => {

function show(stage,id){

let container=document.getElementById(id);

data[stage].forEach(book=>{

let div=document.createElement("div");

div.className="book";

div.innerHTML=
"<span>"+book.name+"</span>"+
"<a href='"+book.file+"' target='_blank'>تحميل</a>";

container.appendChild(div);

});

}

show("primary","primary");

show("middle","middle");

show("secondary","secondary");

});

</script>

</body>

</html>
