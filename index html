<!DOCTYPE html>
<html lang="ar">

<head>
<meta charset="UTF-8">
<title>مكتبة إسماعيل سليمان حسن التعليمية</title>

<style>

body{
font-family:Tahoma;
direction:rtl;
background:#eef2f7;
margin:0;
}

header{
background:#0d6efd;
color:white;
padding:20px;
text-align:center;
font-size:28px;
}

.search{
text-align:center;
margin:15px;
}

input{
width:80%;
padding:10px;
font-size:16px;
}

section{
padding:20px;
}

h2{
background:#198754;
color:white;
padding:10px;
border-radius:5px;
}

.book{
background:white;
margin:8px;
padding:10px;
border-radius:6px;
display:flex;
justify-content:space-between;
align-items:center;
}

a{
background:#0d6efd;
color:white;
padding:6px 12px;
text-decoration:none;
border-radius:4px;
}

</style>

</head>

<body>

<header>
📚 مكتبة إسماعيل سليمان حسن التعليمية
</header>

<div class="search">
<input type="text" id="search" placeholder="🔍 ابحث عن كتاب...">
</div>

<section>

<h2>المرحلة الابتدائية</h2>
<div id="primary"></div>

<h2>المرحلة المتوسطة</h2>
<div id="middle"></div>

<h2>المرحلة الثانوية</h2>
<div id="secondary"></div>

</section>

<script>

let allBooks=[];

fetch("./books.json")
.then(res=>res.json())
.then(data=>{

function show(stage,id){

let container=document.getElementById(id);

data[stage].forEach(book=>{

allBooks.push(book);

let div=document.createElement("div");
div.className="book";

div.innerHTML=
"<span>"+book.name+"</span>"+
"<a href='"+book.file+"' target='_blank'>تحميل</a>";

container.appendChild(div);

});

}

show("primary","primary");
show("middle","middle");
show("secondary","secondary");

});

// البحث
document.getElementById("search").addEventListener("input",function(){

let value=this.value.toLowerCase();

let books=document.querySelectorAll(".book");

books.forEach(b=>{
if(b.innerText.toLowerCase().includes(value)){
b.style.display="flex";
}else{
b.style.display="none";
}
});

});

</script>

</body>
</html>
