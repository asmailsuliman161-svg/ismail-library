<!DOCTYPE html>
<html lang="ar">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>مكتبة إسماعيل سليمان حسن التعليمية</title>
<style>
body { font-family: Tahoma, sans-serif; direction: rtl; margin:0; background:#eef2f7;}
a { text-decoration:none; color:inherit;}
header { background:#0d6efd; color:white; padding:25px; text-align:center;}
header img { width:120px; height:120px; border-radius:50%; margin-bottom:10px; border:3px solid #fff;}
header h1{ margin:0; font-size:28px;}
header p{ margin:5px 0 0 0; font-size:16px;}
.search{ text-align:center; margin:20px;}
.search input{ width:80%; padding:12px; font-size:16px; border-radius:6px; border:1px solid #ccc;}
.container{ width:90%; margin:auto;}
.section{ background:white; padding:20px; margin-bottom:20px; border-radius:10px; box-shadow:0 0 8px #ddd;}
.section h2{ color:#0d6efd; margin-bottom:15px;}
.grade{ margin-bottom:15px;}
.grade h3{ color:#198754; margin-bottom:10px;}
.book{ display:flex; align-items:center; justify-content:space-between; padding:10px; margin:8px 0; background:#f8f9fa; border-radius:6px;}
.book img{ width:50px; height:70px; object-fit:cover; border-radius:4px; margin-left:10px;}
.book-details{ flex:1; margin-right:10px;}
.book-details h3{ margin:0; font-size:16px;}
.book-details p{ margin:3px 0 0 0; font-size:14px; color:#555;}
.book-actions button{ background:#198754; color:white; border:none; padding:6px 12px; border-radius:5px; cursor:pointer;}
.book-actions button:hover{ background:#145c32;}
footer{ background:#333; color:white; text-align:center; padding:15px; margin-top:30px;}
</style>
</head>
<body>

<header>
<img src="arabic1.pdf" alt="صورة الأستاذ إسماعيل">
<h1>الأستاذ إسماعيل سليمان حسن</h1>
<p>ربك – كنانة | السودان</p>
</header>

<div class="search">
<input type="text" id="searchBox" placeholder="ابحث باسم الكتاب أو الصف أو المادة...">
</div>

<div class="container" id="library"></div>

<footer>© مكتبة إسماعيل سليمان حسن التعليمية</footer>

<script>
async function loadBooks(){
  const res = await fetch('books.json');
  const data = await res.json();

  const library = document.getElementById("library");
  library.innerHTML="";

  for(const stage of Object.keys(data)){
    const section = document.createElement("div");
    section.className="section";
    section.innerHTML=`<h2>📖 ${stage}</h2>`;

    for(const book of data[stage]){
      const bookDiv = document.createElement("div");
      bookDiv.className="book";
      bookDiv.innerHTML=`
        <div class="book-details">
          <h3>${book.name}</h3>
          <p>${stage}</p>
        </div>
        <div class="book-actions">
          <button onclick="window.open('${book.file}','_blank')">تحميل</button>
        </div>`;
      section.appendChild(bookDiv);
    }

    library.appendChild(section);
  }

  document.getElementById("searchBox").addEventListener("keyup",function(){
    const filter=this.value.toLowerCase();
    const books=document.querySelectorAll(".book");
    books.forEach(b=>{
      const text=b.querySelector("h3").textContent.toLowerCase();
      b.style.display=text.includes(filter)?'flex':'none';
    });
  });
}

loadBooks();
</script>

</body>
</html>
